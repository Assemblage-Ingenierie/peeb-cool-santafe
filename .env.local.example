# Supabase — copier ce fichier en .env.local et remplir les valeurs
# Ne jamais committer .env.local

# URL du projet Supabase (projet EXTERNAL grnkbnldfzdzrgleorra)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Clé PUBLIQUE (exposée au navigateur) — utilisée par l'authentification.
# Supabase → Project Settings → API. Préférer la clé « publishable » (sb_publishable_…) ;
# l'ancienne clé « anon » fonctionne aussi (repli).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
# (repli accepté si la clé publishable n'est pas fournie)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Clé service_role (SERVEUR uniquement, jamais NEXT_PUBLIC) — requise par
# /api/snapshot et les server actions (lib/supabase/server.ts). À copier depuis
# Supabase → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Bypass d'authentification en DÉVELOPPEMENT (mock admin, aucun login requis).
# Mettre à "true" en dev local. NE JAMAIS activer en production (=> tout le monde
# serait admin). En production : laisser à "false" ou ne pas définir.
NEXT_PUBLIC_DEV_AUTH_BYPASS=true
