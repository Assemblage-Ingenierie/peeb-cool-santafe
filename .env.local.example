# Supabase — copier ce fichier en .env.local et remplir les valeurs
# Ne jamais committer .env.local

# ---- Requises par l'APPLICATION (et par Vercel) --------------------------
# URL et clé anonyme (publique) du projet Supabase (projet EXTERNAL grnkbnldfzdzrgleorra).
# La clé anon est conçue pour être exposée au navigateur ; la RLS protège les données.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Client OAuth « Web » Google (Identity Services) pour le bouton « Continuar con Google »
# (signInWithIdToken → Google affiche notre domaine, pas l'URL Supabase).
# Ajouter les origines de l'app dans « Authorized JavaScript origins » de ce client.
# Finit par .apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Bypass d'authentification en développement local (mock admin).
# À "true" en dev seulement — NE JAMAIS activer en production / sur Vercel.
# NB : en bypass, l'UI est admin mais les données restent soumises à la RLS
# (vides sans vraie session Supabase) → pour tester avec données, se connecter.
NEXT_PUBLIC_DEV_AUTH_BYPASS=true

# ---- Optionnelle : SCRIPTS D'IMPORT LOCAUX uniquement (scripts/*.py) ------
# Clé service_role (bypass RLS) requise SEULEMENT par les scripts Python d'import
# de données lancés en local. L'application ne l'utilise PAS et elle ne doit
# JAMAIS être définie dans Vercel. À copier depuis Supabase → Settings → API.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
