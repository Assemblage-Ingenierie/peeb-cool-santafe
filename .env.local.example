# Supabase — copier ce fichier en .env.local et remplir les valeurs
# Ne jamais committer .env.local

# URL et clé anonyme du projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Bypass d'authentification en développement (mock admin)
# Mettre à "true" en dev, NE JAMAIS activer en production
NEXT_PUBLIC_DEV_AUTH_BYPASS=true
